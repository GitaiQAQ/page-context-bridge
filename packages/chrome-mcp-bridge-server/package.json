{
  "name": "page-context-mcp-bridge",
  "version": "0.1.0",
  "description": "Page Context MCP Bridge - relays extension context tools to MCP clients",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "pnpm --filter @page-context/shared-protocol build && tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "pnpm --filter @page-context/shared-protocol build && tsc -p tsconfig.json --noEmit",
    "test": "pnpm --filter @page-context/shared-protocol build && pnpm --dir ../.. exec vitest run --project node"
  },
  "dependencies": {
    "@page-context/shared-protocol": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "keywords": [
    "mcp",
    "bridge",
    "server",
    "context-bridge"
  ],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.9.2"
  }
}
