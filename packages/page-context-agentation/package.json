{
  "name": "@page-context/agentation",
  "version": "0.0.1",
  "description": "Agentation injection module — MAIN world bridge host installer, React fiber detection, agentation entry point. Extracted from extension core.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@page-context/shared-protocol": "workspace:*"
  },
  "peerDependencies": {
    "@page-context/bridge-extension": "workspace:*"
  },
  "keywords": [
    "page-context",
    "agentation",
    "react-fiber"
  ],
  "license": "MIT"
}
