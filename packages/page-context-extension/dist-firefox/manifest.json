{
  "manifest_version": 3,
  "name": "Page Context Bridge",
  "version": "0.0.1",
  "description": "Expose page-context tools to MCP clients via page-context semantics.",
  "permissions": ["scripting", "tabs", "activeTab", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "scripts": ["src/background.js"],
    "persistent": true
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content-script-main.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["src/content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Page Context Bridge",
    "default_popup": "popup.html"
  },
  "devtools_page": "devtools.html",
  "icons": {
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["loader.html", "agentation-main.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "sidebar_action": {
    "default_panel": "sidepanel.html",
    "default_icon": "icons/icon128.png",
    "default_title": "Page Context Bridge"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "page-context-bridge@example.com",
      "strict_min_version": "121.0"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' ws: wss: http: https:;"
  }
}
