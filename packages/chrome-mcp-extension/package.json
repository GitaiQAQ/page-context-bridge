{
  "name": "page-context-bridge-extension",
  "version": "0.1.0",
  "description": "Page Context Bridge extension for exposing page-aware tools to MCP clients.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev-preview.mjs",
    "build": "pnpm --filter @page-context/shared-protocol build && vite build",
    "typecheck": "pnpm --filter @page-context/shared-protocol build && tsc -p tsconfig.json --noEmit",
    "test": "pnpm --filter @page-context/shared-protocol build && pnpm --dir ../.. exec vitest run --project browser",
    "watch": "web-ext run --source-dir=dist --target=chromium"
  },
  "dependencies": {
    "@page-context/shared-protocol": "workspace:*"
  },
  "keywords": [
    "chrome-extension",
    "mcp",
    "context-bridge",
    "browser"
  ],
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "typescript": "^5.9.2",
    "vite": "^6.2.3",
    "vite-plugin-chrome-extension": "^0.0.7",
    "web-ext": "^10.1.0"
  }
}
