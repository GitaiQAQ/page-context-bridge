{
  "name": "@page-context/mcp-bridge",
  "version": "0.0.2-14",
  "description": "Page Context MCP Bridge - relays extension context tools to MCP clients via stdio/SSE transport",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "page-context-bridge": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build --config vite.config.ts",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --project node",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "bridge",
    "browser-extension",
    "page-context",
    "model-context-protocol",
    "claude",
    "opencode"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "vite": "^8.0.8",
    "@page-context/builtin-tools": "workspace:*",
    "@page-context/shared-protocol": "workspace:*"
  }
}
