{
  "name": "@page-context/tool-visibility",
  "version": "0.0.1",
  "description": "Tool visibility engine — preference management, enable/disable logic, and tool tree builder for page-context tools.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@page-context/builtin-tools": "workspace:*"
  },
  "keywords": [
    "page-context",
    "tool-visibility",
    "preferences",
    "tool-tree"
  ],
  "license": "MIT"
}
