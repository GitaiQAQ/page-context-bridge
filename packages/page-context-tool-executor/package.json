{
  "name": "@page-context/tool-executor",
  "version": "0.0.1",
  "description": "Tool execution engine — CDP client, ServiceWorker context, builtin/page tool dispatch for browser automation.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@page-context/shared-protocol": "workspace:*",
    "@page-context/builtin-tools": "workspace:*",
    "@page-context/tool-visibility": "workspace:*"
  },
  "peerDependencies": {
    "@page-context/bridge-extension": "workspace:*"
  },
  "keywords": [
    "page-context",
    "tool-executor",
    "CDP",
    "chrome-debugger"
  ],
  "license": "MIT"
}
